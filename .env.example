# ═══════════════════════════════════════════════════════════════════════════
# ggboi — Environment Variables
# Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════════════════

# ─── Required ─────────────────────────────────────────────────────────────
# Your Discord bot token from https://discord.com/developers/applications
BOT_TOKEN=

# Comma-separated list of bot owner Discord user IDs
OWNER_IDS=

# ─── Dashboard Auth (pick ONE) ────────────────────────────────────────────
# Option 1: Shared password (simplest)
DASHBOARD_PASSWORD=

# Option 2: Discord OAuth (more secure, multi-user)
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
# DISCORD_REDIRECT_URI=https://bot.yourdomain.com/api/auth/discord/callback

# ─── Dashboard Security (required for production) ─────────────────────────
# Stable secret for JWT signing (64 random hex chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DASHBOARD_JWT_SECRET=

# Comma-separated list of dashboard URLs (CORS whitelist)
DASHBOARD_ORIGIN=https://ggboi-dash.vercel.app

# Optional: JWT expiration (default: 7d)
# DASHBOARD_TOKEN_TTL=7d

# ─── Optional: API Port ───────────────────────────────────────────────────
# API_PORT=3001

# ─── AI Provider Keys (optional — only needed if you enable AI features) ──
# OpenAI
# OPENAI_API_KEY=

# Anthropic Claude
# CLAUDE_API_KEY=

# Google Gemini
# GEMINI_API_KEY=

# Groq (fast, free tier available)
# GROQ_API_KEY=

# Custom / self-hosted endpoint
# CUSTOM_API_KEY=
# CUSTOM_BASE_URL=

# ─── Notes ────────────────────────────────────────────────────────────────
# - Never commit .env to version control (it's in .gitignore)
# - The dashboard SPA is deployed separately (Vercel/Cloudflare Pages)
# - The bot + API run on a VPS (they cannot run on serverless platforms)
# - For full deployment guide, see: scripts/deploy.md
