# ═══════════════════════════════════════════════════════════════════════════════
# ggboi — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The bot + dashboard UI run as a single Express process on one port,
# optimized for Pterodactyl or any single-port environment.

# ─── Required ─────────────────────────────────────────────────────────────────

# Discord bot token — get this from https://discord.com/developers/applications
BOT_TOKEN=your_discord_bot_token_here

# ─── Port ─────────────────────────────────────────────────────────────────────

# Port for the bot API + dashboard UI (Pterodactyl egg standard).
# Only one port is needed — both the API and UI run on this port.
PORT=3432

# ─── Auth ─────────────────────────────────────────────────────────────────────

# Option A: Password login (simple, single-admin)
DASHBOARD_PASSWORD=a_very_strong_password_here

# Option B: Discord OAuth login (more secure for multi-user)
# DISCORD_CLIENT_ID=your_discord_app_id
# DISCORD_CLIENT_SECRET=your_discord_app_secret
# DISCORD_REDIRECT_URI=https://bot.yourdomain.com/api/auth/discord/callback

# ─── HTTPS / Let's Encrypt ─────────────────────────────────────────────────────

# Domain for automatic HTTPS via Caddy (Let's Encrypt, no port 80 needed).
# Set this to your dashboard subdomain (e.g., bot.yourdomain.com) and Caddy
# will automatically provision and renew a trusted SSL certificate.
# Leave blank for HTTP-only mode.
# DOMAIN=subdomain.domain.com

# ─── JWT Secret (Required in Production) ──────────────────────────────────────

# Secret key used to sign dashboard auth tokens.
# Required in production — without it the API will refuse to start.
# Generate a stable 64-character hex string:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DASHBOARD_JWT_SECRET=your_64_char_hex_secret_here

# ─── Owners ───────────────────────────────────────────────────────────────────

# Comma-separated Discord user IDs who are bot owners (full access).
# At least one owner is required — the bot warns on startup if empty.
OWNER_IDS=your_discord_user_id

# ─── Database ─────────────────────────────────────────────────────────────────

# Path to the SQLite database file (optional, default: ./ggboi.sqlite)
# SQLITE_DB_PATH=/data/ggboi.sqlite

# ─── CORS / Origin (For Vercel/External Dashboard Deployments Only) ──────────
# If the dashboard is hosted externally (e.g. on Vercel), set the origin URL(s).
# When serving the dashboard from the same Express process (default), this
# is NOT needed — same-origin requests don't require CORS.
# DASHBOARD_ORIGIN=https://ggboi-dash.vercel.app

# ─── Optional ─────────────────────────────────────────────────────────────────

# JWT token expiry duration (default: 7d)
# DASHBOARD_TOKEN_TTL=7d

# Environment mode (leave unset or set to "production")
# NODE_ENV=production

# Dashboard API URL — only needed when building for external deployment (Vercel)
# VITE_BOT_API_URL=https://bot.yourdomain.com
