# ═══════════════════════════════════════════════════════════════════════════
#  ggboi — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The bot and the dashboard are deployed separately:
#   Bot      → runs on your VPS (node index.js or Docker)
#   Dashboard → static SPA deployed to Vercel
#
# For a complete deployment guide, see: scripts/deploy.md
# ═══════════════════════════════════════════════════════════════════════════

# ─── Required ──────────────────────────────────────────────────────────────

# Your Discord bot token from https://discord.com/developers/applications
BOT_TOKEN=

# ─── Auth (pick at least one) ─────────────────────────────────────────────

# Option A: Password-based login (simplest for single-admin)
# The password dashboard users enter to log in. Use a strong, unique password.
DASHBOARD_PASSWORD=

# Option B: Discord OAuth (recommended for multi-user / extra security)
# Create a Discord app, add a redirect URI, then fill these in.
# When set, Discord OAuth replaces the password login.
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
# DISCORD_REDIRECT_URI=https://bot.yourdomain.com/api/auth/discord/callback

# ─── Required for production ──────────────────────────────────────────────

# Secret used to sign JWT tokens. MUST be a long, stable, random string.
# Generate one with: openssl rand -hex 32
# IMPORTANT: If unset, logins reset on every bot restart.
DASHBOARD_JWT_SECRET=

# Comma-separated list of allowed dashboard origins for CORS.
# Production example: https://ggboi-dash.vercel.app
# Dev fallback (no restriction): leave empty (not recommended in production).
DASHBOARD_ORIGIN=https://ggboi-dash.vercel.app,http://localhost:5173

# ─── Optional ─────────────────────────────────────────────────────────────

# Port the bot's public API listens on (default: 3001)
# API_PORT=3001

# How long a dashboard login JWT stays valid (default: 7d)
# DASHBOARD_TOKEN_TTL=7d

# SQLite database path (default: ./ggboi.sqlite in the project root)
# Use a persistent volume path in Docker deployments.
# SQLITE_DB_PATH=/data/ggboi.sqlite

# ─── AI providers (optional; can also be set from the dashboard AI tab) ─────
# GROQ_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
